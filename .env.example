PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=changeme
ANTHROPIC_API_KEY=sk-ant-...
# HMAC-Secret für kurzlebige signierte URLs (SSE, Attachments, Inline-Bilder).
# Mit `openssl rand -hex 32` generieren. Bei Rotation invalidieren alte Links sofort.
SIGN_SECRET=
# Separater Schlüssel für /admin/*-Endpoints (Embed-Backfill, IMAP-UID-Backfill, Embed-Suche).
# Per X-Admin-Key-Header zu setzen. Leer = /admin/* liefert 503.
# Mit `openssl rand -hex 32` generieren, separat vom PB-Token halten.
ADMIN_API_KEY=
# Xano-Key für User-Rollen-Lookup (optional, leer = Feature deaktiviert)
XANO_API_KEY=
XANO_USER_ROLES_URL=
